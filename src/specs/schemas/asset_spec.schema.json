{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["spec_id", "version", "tile_size", "tilesets", "mappings"],
  "additionalProperties": false,
  "properties": {
    "spec_id": { "type": "string" },
    "version": { "type": "string" },
    "tile_size": { "type": "integer", "minimum": 1 },
    "tilesets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "image", "tile_size", "columns"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "image": { "type": "string" },
          "tile_size": { "type": "integer", "minimum": 1 },
          "columns": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "mappings": {
      "type": "object",
      "required": ["terrain", "features", "entities"],
      "additionalProperties": false,
      "properties": {
        "terrain": { "$ref": "#/$defs/mappingTable" },
        "features": { "$ref": "#/$defs/mappingTable" },
        "entities": { "$ref": "#/$defs/mappingTable" }
      }
    }
  },
  "$defs": {
    "mappingTable": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["tileset", "x", "y"],
        "additionalProperties": false,
        "properties": {
          "tileset": { "type": "string" },
          "x": { "type": "integer", "minimum": 0 },
          "y": { "type": "integer", "minimum": 0 },
          "desc": { "type": "string" }
        }
      }
    }
  }
}
