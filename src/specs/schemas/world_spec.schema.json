{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "world_spec.schema.json",
  "title": "World Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_id", "version", "schema_version", "config", "terrain_types", "features"],
  "properties": {
    "spec_id": { "type": "string" },
    "version": { "type": "string" },
    "schema_version": { "type": "string" },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimensions", "tile_size", "chunk_size"],
      "properties": {
        "dimensions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          }
        },
        "tile_size": { "type": "integer", "minimum": 1 },
        "chunk_size": { "type": "integer", "minimum": 1 }
      }
    },
    "terrain_types": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "walkable", "cost", "yield"],
        "properties": {
          "id": { "type": "integer", "minimum": 0, "maximum": 255 },
          "walkable": { "type": "boolean" },
          "cost": { "type": "integer", "minimum": 0 },
          "yield": {
            "type": "object",
            "additionalProperties": false,
            "required": ["food", "prod", "comm"],
            "properties": {
              "food": { "type": "integer" },
              "prod": { "type": "integer" },
              "comm": { "type": "integer" }
            }
          }
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "integer", "minimum": 0, "maximum": 255 },
          "prod_mod": { "type": "integer" },
          "food_mod": { "type": "integer" },
          "health_mod": { "type": "number" },
          "defense_mod": { "type": "number" }
        }
      }
    }
  }
}
